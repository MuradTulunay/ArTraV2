			FormulaData COUNTDOWN=TDCOUNTDOWN(C,H,L,SETUP); COUNTDOWN.Name="COUNTDOWN";
			FormulaData PERFECTED=TDPERFECTED(H,L,SETUP); PERFECTED.Name="PERFECTED";
			FormulaData BUY_SIGNAL=SETUP==9 | COUNTDOWN==13; BUY_SIGNAL.Name="BUY_SIGNAL";
			FormulaData SELL_SIGNAL=SETUP==-9 | COUNTDOWN==-13; SELL_SIGNAL.Name="SELL_SIGNAL";
