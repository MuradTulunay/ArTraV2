using ArTraV2.Core.Formula;



namespace FML
{
	#region Formula Group TD Sequential Indicators
	[System.Serializable]
	public class TDSEQ_COMPLETE:FormulaBase
	{
		public TDSEQ_COMPLETE():base()
		{
		}
	
		public override FormulaPackage Run(IFormulaDataProvider DP)
		{
			this.DataProvider = DP;
			FormulaData SETUP=TDSETUP(C); SETUP.Name="SETUP";
			FormulaData COUNTDOWN=TDCOUNTDOWN(C,H,L,SETUP); COUNTDOWN.Name="COUNTDOWN";
			FormulaData SIGNAL=IF(COUNTDOWN!=0,COUNTDOWN,SETUP); SIGNAL.Name="SIGNAL";
			FormulaData SUPPORT=TDSUPPORT(H,L,SETUP); SUPPORT.Name="SUPPORT";
			FormulaData RESISTANCE=TDRESISTANCE(H,L,SETUP); RESISTANCE.Name="RESISTANCE";
			FormulaData PERFECTED=TDPERFECTED(H,L,SETUP); PERFECTED.Name="PERFECTED";
			
			return new FormulaPackage(new FormulaData[]{SETUP,COUNTDOWN,SIGNAL,SUPPORT,RESISTANCE,PERFECTED},"");
		}
	
		public override string LongName
		{
			get{return "TD Sequential Complete System";}
		}
	
		public override string Description
		{
			get{return "TD Sequential tam sistemi - Setup, Countdown, TDST çizgileri ve mükemmelleştirme";}
		}
		public override string OutputFields
		{
			get{return "SETUP,COUNTDOWN,SIGNAL,SUPPORT,RESISTANCE,PERFECTED";}
		}
	} //class TDSEQ_COMPLETE

	[System.Serializable]
	public class TDTRADING_ARROWS:FormulaBase
	{
		public double SENSITIVITY=0;
		public double SHOW_PERFECT_ONLY=0;
		public TDTRADING_ARROWS():base()
		{
			AddParam("SENSITIVITY","1","1","3","1","Sinyal hassasiyeti (1=Tüm, 2=Orta, 3=Sadece güçlü)",FormulaParamType.Double);
			AddParam("SHOW_PERFECT_ONLY","0","0","1","1","Sadece mükemmel sinyalleri göster (0=Hayır, 1=Evet)",FormulaParamType.Double);
		}
	
		public override FormulaPackage Run(IFormulaDataProvider DP)
		{
			this.DataProvider = DP;
			FormulaData SETUP=TDSETUP(C); SETUP.Name="SETUP";
			FormulaData COUNTDOWN=TDCOUNTDOWN(C,H,L,SETUP); COUNTDOWN.Name="COUNTDOWN";
			FormulaData PERFECTED=TDPERFECTED(H,L,SETUP); PERFECTED.Name="PERFECTED";
			FormulaData BASIC_BUY=SETUP==9 | COUNTDOWN==13; BASIC_BUY.Name="BASIC_BUY";
			FormulaData BASIC_SELL=SETUP==-9 | COUNTDOWN==-13; BASIC_SELL.Name="BASIC_SELL";
			FormulaData STRONG_BUY=BASIC_BUY & (COUNTDOWN==13 | (SETUP==9 & PERFECTED>0)); STRONG_BUY.Name="STRONG_BUY";
			FormulaData STRONG_SELL=BASIC_SELL & (COUNTDOWN==-13 | (SETUP==-9 & PERFECTED<0)); STRONG_SELL.Name="STRONG_SELL";
			FormulaData PERFECT_BUY=BASIC_BUY & PERFECTED>0; PERFECT_BUY.Name="PERFECT_BUY";
			FormulaData PERFECT_SELL=BASIC_SELL & PERFECTED<0; PERFECT_SELL.Name="PERFECT_SELL";
			FormulaData BUY_SIGNAL=IF(SHOW_PERFECT_ONLY==1,PERFECT_BUY,
IF(SENSITIVITY==3,STRONG_BUY,
IF(SENSITIVITY==2,STRONG_BUY | (BASIC_BUY & COUNTDOWN!=0),BASIC_BUY))); BUY_SIGNAL.Name="BUY_SIGNAL";
			FormulaData SELL_SIGNAL=IF(SHOW_PERFECT_ONLY==1,PERFECT_SELL,
IF(SENSITIVITY==3,STRONG_SELL,
IF(SENSITIVITY==2,STRONG_SELL | (BASIC_SELL & COUNTDOWN!=0),BASIC_SELL))); SELL_SIGNAL.Name="SELL_SIGNAL";
			FormulaData NONAME0=DRAWICON(SELL_SIGNAL , C ,"Sell.Gif");NONAME0.SetAttrs("Top");
			FormulaData NONAME1=DRAWICON(BUY_SIGNAL , C ,"Buy.Gif");NONAME1.SetAttrs("Bottom");
			
			return new FormulaPackage(new FormulaData[]{NONAME0,NONAME1},"");
		}
	
		public override string LongName
		{
			get{return "TD Sequential Trading Arrows";}
		}
	
		public override string Description
		{
			get{return "TD Sequential alım satım okları - Setup ve Countdown sinyalleri ile mükemmel konfigürasyon tespiti";}
		}
		public override string OutputFields
		{
			get{return "DRAWICON(SELL_SIGNAL , C ,\"Sell.Gif\"),DRAWICON(BUY_SIGNAL , C ,\"Buy.Gif\")";}
		}
	} //class TDTRADING_ARROWS

	[System.Serializable]
	public class TDTRADING_COMPLETE:FormulaBase
	{
		public double SENSITIVITY=0;
		public double SHOW_PERFECT_ONLY=0;
		public double SHOW_SUPPORT_RESISTANCE=0;
		public TDTRADING_COMPLETE():base()
		{
			AddParam("SENSITIVITY","2","1","3","1","Sinyal hassasiyeti (1=Tüm, 2=Orta, 3=Sadece güçlü)",FormulaParamType.Double);
			AddParam("SHOW_PERFECT_ONLY","0","0","1","1","Sadece mükemmel sinyalleri göster (0=Hayır, 1=Evet)",FormulaParamType.Double);
			AddParam("SHOW_SUPPORT_RESISTANCE","1","0","1","1","Destek/Direnç çizgilerini göster (0=Hayır, 1=Evet)",FormulaParamType.Double);
		}
	
		public override FormulaPackage Run(IFormulaDataProvider DP)
		{
			this.DataProvider = DP;
			FormulaData SETUP=TDSETUP(C); SETUP.Name="SETUP";
			FormulaData COUNTDOWN=TDCOUNTDOWN(C,H,L,SETUP); COUNTDOWN.Name="COUNTDOWN";
			FormulaData PERFECTED=TDPERFECTED(H,L,SETUP); PERFECTED.Name="PERFECTED";
			FormulaData SUPPORT_LINES=IF(SHOW_SUPPORT_RESISTANCE==1,TDSUPPORT(H,L,SETUP),0); SUPPORT_LINES.Name="SUPPORT_LINES";
			FormulaData RESISTANCE_LINES=IF(SHOW_SUPPORT_RESISTANCE==1,TDRESISTANCE(H,L,SETUP),0); RESISTANCE_LINES.Name="RESISTANCE_LINES";
			FormulaData BASIC_BUY=SETUP==9 | COUNTDOWN==13; BASIC_BUY.Name="BASIC_BUY";
			FormulaData BASIC_SELL=SETUP==-9 | COUNTDOWN==-13; BASIC_SELL.Name="BASIC_SELL";
			FormulaData STRONG_BUY=BASIC_BUY & (COUNTDOWN==13 | (SETUP==9 & PERFECTED>0)); STRONG_BUY.Name="STRONG_BUY";
			FormulaData STRONG_SELL=BASIC_SELL & (COUNTDOWN==-13 | (SETUP==-9 & PERFECTED<0)); STRONG_SELL.Name="STRONG_SELL";
			FormulaData PERFECT_BUY=BASIC_BUY & PERFECTED>0; PERFECT_BUY.Name="PERFECT_BUY";
			FormulaData PERFECT_SELL=BASIC_SELL & PERFECTED<0; PERFECT_SELL.Name="PERFECT_SELL";
			FormulaData BUY_SIGNAL=IF(SHOW_PERFECT_ONLY==1,PERFECT_BUY,
            IF(SENSITIVITY==3,STRONG_BUY,
            IF(SENSITIVITY==2,STRONG_BUY | (BASIC_BUY & COUNTDOWN!=0),BASIC_BUY))); BUY_SIGNAL.Name="BUY_SIGNAL";
			FormulaData SELL_SIGNAL=IF(SHOW_PERFECT_ONLY==1,PERFECT_SELL,
            IF(SENSITIVITY==3,STRONG_SELL,
            IF(SENSITIVITY==2,STRONG_SELL | (BASIC_SELL & COUNTDOWN!=0),BASIC_SELL))); SELL_SIGNAL.Name="SELL_SIGNAL";
			FormulaData NONAME0=DRAWICON(SELL_SIGNAL , C ,"Sell.Gif");NONAME0.SetAttrs("Top");
			FormulaData NONAME1=DRAWICON(BUY_SIGNAL , C ,"Buy.Gif");NONAME1.SetAttrs("Bottom");
			
			return new FormulaPackage(new FormulaData[]{SUPPORT_LINES,RESISTANCE_LINES,NONAME0,NONAME1},"");
		}
	
		public override string LongName
		{
			get{return "TD Sequential Complete Trading System";}
		}
	
		public override string Description
		{
			get{return "TD Sequential tam alım satım sistemi - Tüm sinyaller, destek-direnç çizgileri ve mükemmelleştirme";}
		}
		public override string OutputFields
		{
			get{return "SUPPORT_LINES,RESISTANCE_LINES,DRAWICON(SELL_SIGNAL , C ,\"Sell.Gif\"),DRAWICON(BUY_SIGNAL , C ,\"Buy.Gif\")";}
		}
	} //class TDTRADING_COMPLETE

	[System.Serializable]
	public class TDSEQ_SR:FormulaBase
	{
		public TDSEQ_SR():base()
		{
		}
	
		public override FormulaPackage Run(IFormulaDataProvider DP)
		{
			this.DataProvider = DP;
			FormulaData SETUP=TDSETUP(C); SETUP.Name="SETUP";
			FormulaData SUPPORT_LINES=TDSUPPORTMULTI(H,L,SETUP); SUPPORT_LINES.Name="SUPPORT_LINES";
			FormulaData RESISTANCE_LINES=TDRESISTANCEMULTI(H,L,SETUP); RESISTANCE_LINES.Name="RESISTANCE_LINES";
			FormulaData PREV1_H=REF(H,1); PREV1_H.Name="PREV1_H";
			FormulaData PREV1_L=REF(L,1); PREV1_L.Name="PREV1_L";
			FormulaData PREV2_H=REF(H,2); PREV2_H.Name="PREV2_H";
			FormulaData PREV2_L=REF(L,2); PREV2_L.Name="PREV2_L";
			FormulaData PREV1_SUPPORT=REF(SUPPORT_LINES,1); PREV1_SUPPORT.Name="PREV1_SUPPORT";
			FormulaData PREV1_RESISTANCE=REF(RESISTANCE_LINES,1); PREV1_RESISTANCE.Name="PREV1_RESISTANCE";
			FormulaData PREV2_SUPPORT=REF(SUPPORT_LINES,2); PREV2_SUPPORT.Name="PREV2_SUPPORT";
			FormulaData PREV2_RESISTANCE=REF(RESISTANCE_LINES,2); PREV2_RESISTANCE.Name="PREV2_RESISTANCE";
			FormulaData PREV_BELOW_SUPPORT=(PREV1_H < PREV2_SUPPORT) | (PREV1_L < PREV2_SUPPORT); PREV_BELOW_SUPPORT.Name="PREV_BELOW_SUPPORT";
			FormulaData NOW_ABOVE_SUPPORT=L >= PREV1_SUPPORT; NOW_ABOVE_SUPPORT.Name="NOW_ABOVE_SUPPORT";
			FormulaData SUPPORT_BUY=PREV_BELOW_SUPPORT & NOW_ABOVE_SUPPORT; SUPPORT_BUY.Name="SUPPORT_BUY";
			FormulaData PREV_BELOW_RESISTANCE=(PREV1_H < PREV2_RESISTANCE) | (PREV1_L < PREV2_RESISTANCE); PREV_BELOW_RESISTANCE.Name="PREV_BELOW_RESISTANCE";
			FormulaData NOW_ABOVE_RESISTANCE=L >= PREV1_RESISTANCE; NOW_ABOVE_RESISTANCE.Name="NOW_ABOVE_RESISTANCE";
			FormulaData RESISTANCE_BUY=PREV_BELOW_RESISTANCE & NOW_ABOVE_RESISTANCE; RESISTANCE_BUY.Name="RESISTANCE_BUY";
			FormulaData PREV_ABOVE_SUPPORT=(PREV1_L > PREV2_SUPPORT) | (PREV1_H > PREV2_SUPPORT); PREV_ABOVE_SUPPORT.Name="PREV_ABOVE_SUPPORT";
			FormulaData NOW_BELOW_SUPPORT=H <= PREV1_SUPPORT; NOW_BELOW_SUPPORT.Name="NOW_BELOW_SUPPORT";
			FormulaData SUPPORT_SELL=PREV_ABOVE_SUPPORT & NOW_BELOW_SUPPORT; SUPPORT_SELL.Name="SUPPORT_SELL";
			FormulaData PREV_ABOVE_RESISTANCE=(PREV1_L > PREV2_RESISTANCE) | (PREV1_H > PREV2_RESISTANCE); PREV_ABOVE_RESISTANCE.Name="PREV_ABOVE_RESISTANCE";
			FormulaData NOW_BELOW_RESISTANCE=H <= PREV1_RESISTANCE; NOW_BELOW_RESISTANCE.Name="NOW_BELOW_RESISTANCE";
			FormulaData RESISTANCE_SELL=PREV_ABOVE_RESISTANCE & NOW_BELOW_RESISTANCE; RESISTANCE_SELL.Name="RESISTANCE_SELL";
			FormulaData BUY_SIGNAL=SUPPORT_BUY | RESISTANCE_BUY; BUY_SIGNAL.Name="BUY_SIGNAL";
			FormulaData SELL_SIGNAL=SUPPORT_SELL | RESISTANCE_SELL; SELL_SIGNAL.Name="SELL_SIGNAL";
			FormulaData NONAME0=DRAWICON(BUY_SIGNAL,L,"AltBuy.gif");NONAME0.SetAttrs("Bottom");
			FormulaData NONAME1=DRAWICON(SELL_SIGNAL,H,"AltSell.gif");NONAME1.SetAttrs("Top");
			FormulaData SIGNAL_DIRECTION=IF(BUY_SIGNAL,1,IF(SELL_SIGNAL,-1,0)); SIGNAL_DIRECTION.Name="SIGNAL_DIRECTION";
			return new FormulaPackage(new FormulaData[]{SETUP,SUPPORT_LINES,RESISTANCE_LINES,NONAME0,NONAME1,SIGNAL_DIRECTION},"");
		}
	
		public override string LongName
		{
			get{return "TD Sequential Support/Resistance Breakout Signals";}
		}
	
		public override string Description
		{
			get{return "TD Sequential destek/direnç çizgilerinin tam kırılım sinyalleri. Bir önceki barda OHLC değerleri çizginin bütünüyle/kısmen altında/üstündeyken, yeni barda bütünüyle karşı tarafa geçtiğinde sinyal üretir.";}
		}
		public override string OutputFields
		{
			get{return "SETUP,SUPPORT_LINES,RESISTANCE_LINES,DRAWICON(BUY_SIGNAL,L,\"AltBuy.gif\"),DRAWICON(SELL_SIGNAL,H,\"AltSell.gif\"),SIGNAL_DIRECTION";}
		}
	} //class TDSEQ_SR

