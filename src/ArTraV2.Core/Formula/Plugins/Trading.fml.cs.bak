				FormulaData NONAME0=DRAWICON(SELL , C ,"Sell.Gif");NONAME0.SetAttrs("Top");
				FormulaData NONAME1=DRAWICON(BUY , C ,"Buy.Gif");NONAME1.SetAttrs("Bottom");
				FormulaData NONAME2=DRAWICON(OPENSELL , C ,"OpenSell.Gif");NONAME2.SetAttrs("Top");
				FormulaData NONAME3=DRAWICON(CLOSEOPENSELL, C ,"CloseOpenSell.Gif");NONAME3.SetAttrs("Bottom");
				FormulaData STOPBUYS= STOPLOSS>0; STOPBUYS.Name="STOPBUYS";
				FormulaData STOPSELLS=STOPLOSS<0; STOPSELLS.Name="STOPSELLS";
				FormulaData NONAME4=DRAWICON(STOPSELLS , C ,"StopSell.Gif");NONAME4.SetAttrs("Top");
				FormulaData NONAME5=DRAWICON(STOPBUYS , C ,"StopBuy.Gif");NONAME5.SetAttrs("Bottom");
				
				return new FormulaPackage(new FormulaData[]{NONAME0,NONAME1,NONAME2,NONAME3,NONAME4,NONAME5},"");
