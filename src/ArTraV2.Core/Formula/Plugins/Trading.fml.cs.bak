		[System.Serializable]
		public class _T_SAR_ASSL:FormulaBase
		{
			public double N=0;
			public double STEP=0;
			public double MAXP=0;
			public double SL=0;
			public _T_SAR_ASSL():base()
			{
				AddParam("N","2","1","100","2","",FormulaParamType.Double);
				AddParam("STEP","2","1","100","2","",FormulaParamType.Double);
				AddParam("MAXP","2","1","100","2","",FormulaParamType.Double);
				AddParam("SL","0","0","100","0","",FormulaParamType.Double);
			}
		
			public override FormulaPackage Run(IFormulaDataProvider DP)
			{
				this.DataProvider = DP;
				FormulaData BUY=SARTURN(N,STEP,MAXP)==1; BUY.Name="BUY";
				FormulaData SELL=SARTURN(N,STEP,MAXP)==-1; SELL.Name="SELL";SELL.SetAttrs("ColorRed");
				FormulaData ALTBUY= EMPTY; ALTBUY.Name="ALTBUY";
				FormulaData ALTSELL=EMPTY; ALTSELL.Name="ALTSELL";
				FormulaData STOPLOSS=EMPTY; STOPLOSS.Name="STOPLOSS";
				FormulaData BALANCE= 10000.0; BALANCE.Name="BALANCE";
				FormulaData BT= BACKTEST(C,BUY,SELL,0,0,BALANCE[0],0.000342,1,ALTBUY,ALTSELL,SL,STOPLOSS); BT.Name="BT";
				FormulaData NONAME0=DRAWICON(SELL , BT ,"Sell.Gif");NONAME0.SetAttrs("Top");
				FormulaData NONAME1=DRAWICON(BUY , BT ,"Buy.Gif");NONAME1.SetAttrs("Bottom");
				FormulaData STOPBUYS= STOPLOSS>0; STOPBUYS.Name="STOPBUYS";
				FormulaData STOPSELLS=STOPLOSS<0; STOPSELLS.Name="STOPSELLS";
				FormulaData NONAME2=DRAWICON(STOPSELLS , BT ,"StopSell.Gif");NONAME2.SetAttrs("Top");
				FormulaData NONAME3=DRAWICON(STOPBUYS , BT ,"StopBuy.Gif");NONAME3.SetAttrs("Bottom");
				FormulaData MAXPERF= (BALANCE/LLV(L))*HHV(H); MAXPERF.Name="MaxPerf";
				FormulaData NONAME4=BT;
				FormulaData NONAME5=MAXPERF;NONAME5.SetAttrs(" DarkGreen,Width2");
				return new FormulaPackage(new FormulaData[]{NONAME0,NONAME1,NONAME2,NONAME3,NONAME4,NONAME5},"");
			}
		
			public override string LongName
			{
				get{return "";}
			}
		
			public override string Description
			{
				get{return "RSI Trading system\n\n\n\n\n";}
			}
			public override string OutputFields
			{
				get{return "DRAWICON(SELL , BT ,\"Sell.Gif\"),DRAWICON(BUY , BT ,\"Buy.Gif\"),DRAWICON(STOPSELLS , BT ,\"StopSell.Gif\"),DRAWICON(STOPBUYS , BT ,\"StopBuy.Gif\"),BT,MaxPerf";}
			}
		} //class _T_SAR_ASSL

		[System.Serializable]
		public class A_SAR_ASSL:FormulaBase
		{
			public double N=0;
			public double STEP=0;
			public double MAXP=0;
			public double SL=0;
			public A_SAR_ASSL():base()
			{
				AddParam("N","2","1","100","2","",FormulaParamType.Double);
				AddParam("STEP","2","1","100","2","",FormulaParamType.Double);
				AddParam("MAXP","2","1","100","2","",FormulaParamType.Double);
				AddParam("SL","0","0","100","0","",FormulaParamType.Double);
			}
		
			public override FormulaPackage Run(IFormulaDataProvider DP)
			{
				this.DataProvider = DP;
				FormulaData BUY=SARTURN(N,STEP,MAXP)==1; BUY.Name="BUY";
				FormulaData SELL=SARTURN(N,STEP,MAXP)==-1; SELL.Name="SELL";SELL.SetAttrs("ColorRed");
				FormulaData ALTBUY= EMPTY; ALTBUY.Name="ALTBUY";
				FormulaData ALTSELL=EMPTY; ALTSELL.Name="ALTSELL";
				FormulaData STOPLOSS=EMPTY; STOPLOSS.Name="STOPLOSS";
				FormulaData BALANCE= 10000.0; BALANCE.Name="BALANCE";
				FormulaData BT= BACKTEST(C,BUY,SELL,0,0,BALANCE[0],0.000342,1,ALTBUY,ALTSELL,SL,STOPLOSS); BT.Name="BT";
				FormulaData NONAME0=DRAWICON(SELL , C ,"Sell.Gif");NONAME0.SetAttrs("Top");
				FormulaData NONAME1=DRAWICON(BUY , C ,"Buy.Gif");NONAME1.SetAttrs("Bottom");
				FormulaData STOPBUYS= STOPLOSS>0; STOPBUYS.Name="STOPBUYS";
				FormulaData STOPSELLS=STOPLOSS<0; STOPSELLS.Name="STOPSELLS";
				FormulaData NONAME2=DRAWICON(STOPSELLS , ABS(STOPLOSS) ,"StopSell.Gif");NONAME2.SetAttrs("Top");
				FormulaData NONAME3=DRAWICON(STOPBUYS , STOPLOSS ,"StopBuy.Gif");NONAME3.SetAttrs("Bottom");
				
				return new FormulaPackage(new FormulaData[]{NONAME0,NONAME1,NONAME2,NONAME3},"");
			}
		
			public override string LongName
			{
				get{return "";}
			}
		
			public override string Description
			{
				get{return "RSI Trading system\n\n\n\n\n";}
			}
			public override string OutputFields
			{
				get{return "DRAWICON(SELL , C ,\"Sell.Gif\"),DRAWICON(BUY , C ,\"Buy.Gif\"),DRAWICON(STOPSELLS , ABS(STOPLOSS) ,\"StopSell.Gif\"),DRAWICON(STOPBUYs , STOPLOSS ,\"StopBuy.Gif\")";}
			}
		} //class A_SAR_ASSL

		[System.Serializable]
		public class _T_MA_TRIPLESL:FormulaBase
		{
			public double T=0;
			public double N=0;
			public double M=0;
			public double SL=0;
			public _T_MA_TRIPLESL():base()
			{
				AddParam("T","5","3","14","1","",FormulaParamType.Double);
				AddParam("N","5","3","200","1","",FormulaParamType.Double);
				AddParam("M","5","3","200","1","",FormulaParamType.Double);
				AddParam("SL","0","0","100","0","",FormulaParamType.Double);
			}
		
			public override FormulaPackage Run(IFormulaDataProvider DP)
			{
				this.DataProvider = DP;
				FormulaData MAN=MA(C,N); MAN.Name="MAN";
				FormulaData MAM=MA(C,M); MAM.Name="MAM";
				FormulaData MAT=MA(C,T); MAT.Name="MAT";
				FormulaData BUY=CROSS(MAT,MAN); BUY.Name="BUY";
				FormulaData SELL=CROSS(MAM,MAT); SELL.Name="SELL";
				FormulaData ALTBUY= EMPTY; ALTBUY.Name="ALTBUY";
				FormulaData ALTSELL=EMPTY; ALTSELL.Name="ALTSELL";
				FormulaData STOPLOSS=EMPTY; STOPLOSS.Name="STOPLOSS";
				FormulaData BALANCE= 10000.0; BALANCE.Name="BALANCE";
				FormulaData BT= BACKTEST(C,BUY,SELL,0,0,BALANCE[0],0.000342,1,ALTBUY,ALTSELL,SL,STOPLOSS); BT.Name="BT";
				FormulaData NONAME0=DRAWICON(SELL , BT ,"Sell.Gif");NONAME0.SetAttrs("Top");
				FormulaData NONAME1=DRAWICON(BUY , BT ,"Buy.Gif");NONAME1.SetAttrs("Bottom");
				FormulaData STOPBUYS= STOPLOSS==1; STOPBUYS.Name="STOPBUYS";
				FormulaData STOPSELLS=STOPLOSS==-1; STOPSELLS.Name="STOPSELLS";
				FormulaData NONAME2=DRAWICON(STOPSELLS , BT ,"StopSell.Gif");NONAME2.SetAttrs("Top");
				FormulaData NONAME3=DRAWICON(STOPBUYS , BT ,"StopBuy.Gif");NONAME3.SetAttrs("Bottom");
				FormulaData MAXPERF= (BALANCE/LLV(L))*HHV(H); MAXPERF.Name="MaxPerf";
				FormulaData NONAME4=BT;
				FormulaData NONAME5=MAXPERF;NONAME5.SetAttrs(" DarkGreen,Width2");
				return new FormulaPackage(new FormulaData[]{NONAME0,NONAME1,NONAME2,NONAME3,NONAME4,NONAME5},"");
			}
		
