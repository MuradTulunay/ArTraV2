		[System.Serializable]
		public class A_SAR_SA:FormulaBase
		{
			public double N=0;
			public double STEP=0;
			public double MAXP=0;
			public A_SAR_SA():base()
			{
				AddParam("N","2","1","100","2","",FormulaParamType.Double);
				AddParam("STEP","2","1","100","2","",FormulaParamType.Double);
				AddParam("MAXP","2","1","100","2","",FormulaParamType.Double);
			}
		
			public override FormulaPackage Run(IFormulaDataProvider DP)
			{
				this.DataProvider = DP;
				FormulaData CLOSEOPENPOSITION=SARTURN(N,STEP,MAXP)==1; CLOSEOPENPOSITION.Name="CLOSEOPENPOSITION";
				FormulaData OPENSELL=SARTURN(N,STEP,MAXP)==-1; OPENSELL.Name="OPENSELL";OPENSELL.SetAttrs("ColorRed");
				FormulaData ALTBUY= EMPTY; ALTBUY.Name="ALTBUY";
				FormulaData ALTSELL=EMPTY; ALTSELL.Name="ALTSELL";
				FormulaData BALANCE= 10000.0; BALANCE.Name="BALANCE";
				FormulaData NONAME0=DRAWICON(OPENSELL , C ,"OpenSell.Gif");NONAME0.SetAttrs("Top");
				FormulaData NONAME1=DRAWICON(CLOSEOPENPOSITION, C ,"CloseOpenSell.Gif");NONAME1.SetAttrs("Bottom");
				
				return new FormulaPackage(new FormulaData[]{NONAME0,NONAME1},"");
			}
		
