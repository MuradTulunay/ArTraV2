				get{return "DRAWICON(SELL , C ,\"Sell.Gif\"),DRAWICON(BUY , C ,\"Buy.Gif\"),DRAWICON(STOPSELLS , C ,\"StopSell.Gif\"),DRAWICON(STOPBUYS , C ,\"StopBuy.Gif\"),DRAWICON(DSELL , C ,\"OpenSell.Gif\"),DRAWICON(DBUY, C ,\"CloseOpenSell.Gif\")";}
			}
		} //class A_ZIGWAD

		[System.Serializable]
		public class _T_WADVSL:FormulaBase
		{
			public double N=0;
			public double M=0;
			public double SL=0;
			public _T_WADVSL():base()
			{
				AddParam("N","20","10","400","5","",FormulaParamType.Double);
				AddParam("M","1500","600","10000","50","",FormulaParamType.Double);
				AddParam("SL","0","0","100","0","",FormulaParamType.Double);
			}
		
			public override FormulaPackage Run(IFormulaDataProvider DP)
			{
				this.DataProvider = DP;
				FormulaData AD=SUM(IF( CLOSE>REF(CLOSE,1),CLOSE-MIN(REF(CLOSE,1),LOW),IF(CLOSE<REF(CLOSE,1),
CLOSE-MAX(REF(CLOSE,1),HIGH),0)),0); AD.Name="AD";
				FormulaData SIG=VOL/REPEAT > M; SIG.Name="SIG";
				FormulaData LL=LLV(AD,N); LL.Name="LL";
				FormulaData HH= HHV(AD,N); HH.Name="HH";
				FormulaData BUYO= IF(SIG & AD==LL,1, 0); BUYO.Name="BUYO";
				FormulaData SELLO= IF(SIG & AD==HH,-1,0); SELLO.Name="SELLO";
				FormulaData BUYC= BUYO & AD==HH; BUYC.Name="BUYC";
				FormulaData SELLC=SELLO & AD==LL; SELLC.Name="SELLC";
				FormulaData BUY= BUYO; BUY.Name="BUY";
				FormulaData SELL= SELLO | SELLC; SELL.Name="SELL";
				FormulaData OPENSELL=SELLO; OPENSELL.Name="OPENSELL";
				FormulaData CLOSEOPENSELL=BUYO | BUYC; CLOSEOPENSELL.Name="CloseOpenSell";
				FormulaData ALTBUY= EMPTY; ALTBUY.Name="ALTBUY";
				FormulaData ALTSELL=EMPTY; ALTSELL.Name="ALTSELL";
				FormulaData STOPLOSS=EMPTY; STOPLOSS.Name="STOPLOSS";
				FormulaData BALANCE= 10000.0; BALANCE.Name="BALANCE";
				FormulaData BT= BACKTEST(C,BUY,SELL,OPENSELL,CLOSEOPENSELL,BALANCE[0],0.000342,1,ALTBUY,ALTSELL,SL,STOPLOSS); BT.Name="BT";
				FormulaData NONAME0=DRAWICON(SELL , BT ,"Sell.Gif");NONAME0.SetAttrs("Top");
				FormulaData NONAME1=DRAWICON(BUY , BT ,"Buy.Gif");NONAME1.SetAttrs("Bottom");
				FormulaData NONAME2=DRAWICON(OPENSELL , BT ,"OpenSell.Gif");NONAME2.SetAttrs("Top");
				FormulaData NONAME3=DRAWICON(CLOSEOPENSELL, BT ,"CloseOpenSell.Gif");NONAME3.SetAttrs("Bottom");
				FormulaData STOPBUYS= STOPLOSS>0; STOPBUYS.Name="STOPBUYS";
				FormulaData STOPSELLS=STOPLOSS<0; STOPSELLS.Name="STOPSELLS";
				FormulaData NONAME4=DRAWICON(STOPSELLS , BT ,"StopSell.Gif");NONAME4.SetAttrs("Top");
				FormulaData NONAME5=DRAWICON(STOPBUYS , BT ,"StopBuy.Gif");NONAME5.SetAttrs("Bottom");
				FormulaData MAXPERF= (BALANCE/LLV(L))*HHV(H); MAXPERF.Name="MaxPerf";
				FormulaData NONAME6=BT;
				FormulaData NONAME7=MAXPERF;NONAME7.SetAttrs(" DarkGreen,Width2");
				return new FormulaPackage(new FormulaData[]{NONAME0,NONAME1,NONAME2,NONAME3,NONAME4,NONAME5,NONAME6,NONAME7},"");
			}
		
			public override string LongName
			{
				get{return "";}
			}
		
			public override string Description
			{
				get{return "Williams Accumulation distirbution indicatörünün dip ve tepelerine denk gelen > 3000 miktarlı barlarda (H+L)/2 fiyatlı işlem girilir.\n\nBUY:=SIG>1;\nSELL:=SIG<-1,ColorRed;\nALTBUY:= EMPTY;\nALTSELL:=EMPTY;\nSTOPLOSS:=EMPTY;\nBALANCE := 10000.0;\nBT:= BACKTEST(C,BUY,SELL,0,0,BALANCE[0],0.000342,1,ALTBUY,ALTSELL,SL,STOPLOSS,0.00,true);\n\nDRAWICON(SELL , BT ,'Sell.Gif'),Top;\nDRAWICON(BUY , BT ,'Buy.Gif'),Bottom;\n\nSTOPBUYS:= STOPLOSS>0;\nSTOPSELLS:=STOPLOSS<0;\nDRAWICON(STOPSELLS , BT ,'StopSell.Gif'),Top;\nDRAWICON(STOPBUYS , BT ,'StopBuy.Gif'),Bottom;\n\n\nMaxPerf:= (BALANCE/LLV(L))*HHV(H);\nBT\n\n\n";}
			}
			public override string OutputFields
			{
				get{return "DRAWICON(SELL , BT ,\"Sell.Gif\"),DRAWICON(BUY , BT ,\"Buy.Gif\"),DRAWICON(OPENSELL , BT ,\"OpenSell.Gif\"),DRAWICON(CloseOpenSell, BT ,\"CloseOpenSell.Gif\"),DRAWICON(STOPSELLS , BT ,\"StopSell.Gif\"),DRAWICON(STOPBUYS , BT ,\"StopBuy.Gif\"),BT,MaxPerf";}
			}
		} //class _T_WADVSL

		[System.Serializable]
