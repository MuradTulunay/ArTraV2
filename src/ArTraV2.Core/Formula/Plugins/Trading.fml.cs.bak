using ArTraV2.Core.Formula;



namespace FML
{
	namespace Trading
	{
		[System.Serializable]
		public class _T_RSI_AS:FormulaBase
		{
			public double N=0;
			public double UP=0;
			public double DW=0;
			public _T_RSI_AS():base()
			{
				AddParam("N","3","2","21","1","",FormulaParamType.Double);
				AddParam("UP","-80","-95","95","5","",FormulaParamType.Double);
				AddParam("DW","5","-95","95","3","",FormulaParamType.Double);
			}
		
			public override FormulaPackage Run(IFormulaDataProvider DP)
			{
				this.DataProvider = DP;
				FormulaData BUY=CROSS(FML(DP,"RSI(N)"),DW); BUY.Name="BUY";BUY.SetAttrs("ColorDarkGreen");
				FormulaData SELL=CROSS(UP,FML(DP,"RSI(N)")); SELL.Name="SELL";SELL.SetAttrs("ColorRed");
				FormulaData ALTBUY= EMPTY; ALTBUY.Name="ALTBUY";
				FormulaData ALTSELL=EMPTY; ALTSELL.Name="ALTSELL";
				FormulaData BALANCE= 10000.0; BALANCE.Name="BALANCE";
				FormulaData BT= BACKTEST(C,BUY,SELL,0,0,BALANCE[0],0.000342,1,ALTBUY,ALTSELL); BT.Name="BT";
				FormulaData NONAME0=DRAWICON(SELL , BT ,"Sell.Gif");NONAME0.SetAttrs("Top");
				FormulaData NONAME1=DRAWICON(BUY , BT ,"Buy.Gif");NONAME1.SetAttrs("Bottom");
				FormulaData MAXPERF= (BALANCE/LLV(L))*HHV(H); MAXPERF.Name="MaxPerf";
				FormulaData NONAME2=BT;
				FormulaData NONAME3=MAXPERF;NONAME3.SetAttrs(" DarkGreen,Width2");
				return new FormulaPackage(new FormulaData[]{NONAME0,NONAME1,NONAME2,NONAME3},"");
			}
		
			public override string LongName
			{
				get{return "RSI Trading System Sadece normal Al-Sat";}
			}
		
			public override string Description
			{
				get{return "RSI Trading system\n\n\n\n\n";}
			}
			public override string OutputFields
			{
				get{return "DRAWICON(SELL , BT ,\"Sell.Gif\"),DRAWICON(BUY , BT ,\"Buy.Gif\"),BT,MaxPerf";}
			}
		} //class _T_RSI_AS

		[System.Serializable]
		public class _T_RSI_OS:FormulaBase
		{
			public double N=0;
			public double OUP=0;
			public double ODW=0;
			public _T_RSI_OS():base()
			{
				AddParam("N","3","3","8","2","",FormulaParamType.Double);
				AddParam("OUP","70","-95","95","1","",FormulaParamType.Double);
				AddParam("ODW","30","-95","95","1","",FormulaParamType.Double);
			}
		
			public override FormulaPackage Run(IFormulaDataProvider DP)
			{
				this.DataProvider = DP;
				FormulaData CLOSEOPENPOSITION=CROSS(FML(DP,"RSI(N)"),ODW); CLOSEOPENPOSITION.Name="CLOSEOPENPOSITION";CLOSEOPENPOSITION.SetAttrs("ColorDarkGreen");
				FormulaData OPENSELL=CROSS(OUP,FML(DP,"RSI(N)")); OPENSELL.Name="OPENSELL";OPENSELL.SetAttrs("ColorRed");
				FormulaData ALTBUY= EMPTY; ALTBUY.Name="ALTBUY";
				FormulaData ALTSELL=EMPTY; ALTSELL.Name="ALTSELL";
				FormulaData BALANCE= 10000.0; BALANCE.Name="BALANCE";
				FormulaData BT= BACKTEST(C,0,0,OPENSELL,CLOSEOPENPOSITION,BALANCE[0],0.000342,1,ALTBUY,ALTSELL); BT.Name="BT";
				FormulaData NONAME0=DRAWICON(OPENSELL, BT ,"OpenSell.Gif");NONAME0.SetAttrs("Top");
				FormulaData NONAME1=DRAWICON(CLOSEOPENPOSITION, BT ,"CloseOpenSell.Gif");NONAME1.SetAttrs("Bottom");
				FormulaData AMT= BALANCE/C[0]; AMT.Name="AMT";
				FormulaData MAXPERF= (BALANCE/LLV(L))*HHV(H); MAXPERF.Name="MaxPerf";
				FormulaData NONAME2=BT;
				FormulaData PERF=C*AMT; PERF.Name="Perf";
				FormulaData NONAME3=BALANCE;NONAME3.SetAttrs("ColorDarkRed");
				FormulaData NONAME4=MAXPERF;NONAME4.SetAttrs(" DarkGreen,Width2");
				return new FormulaPackage(new FormulaData[]{NONAME0,NONAME1,NONAME2,PERF,NONAME3,NONAME4},"");
			}
		
			public override string LongName
			{
				get{return "RSI Trading System Sadece Açığa satış";}
			}
		
			public override string Description
			{
				get{return "RSI Trading system";}
			}
			public override string OutputFields
			{
				get{return "DRAWICON(OPENSELL, BT ,\"OpenSell.Gif\"),DRAWICON(CLOSEOPENPOSITION, BT ,\"CloseOpenSell.Gif\"),BT,Perf,BALANCE,MaxPerf";}
			}
		} //class _T_RSI_OS

		[System.Serializable]
		public class MACD:FormulaBase
		{
			public double N1=0;
			public double N2=0;
			public double N3=0;
			public MACD():base()
			{
				AddParam("N1","26","13","40","1","",FormulaParamType.Double);
				AddParam("N2","12","6","26","1","",FormulaParamType.Double);
				AddParam("N3","9","3","9","1","",FormulaParamType.Double);
			}
		
			public override FormulaPackage Run(IFormulaDataProvider DP)
			{
				this.DataProvider = DP;
				FormulaData BUY=LONGCROSS(FML(DP,"MACD(N1,N2,N3)"),0.2,3); BUY.Name="BUY";
				FormulaData SELL=LONGCROSS(-0.2,FML(DP,"MACD(N1,N2,N3)"),3); SELL.Name="SELL";
				FormulaData ALTBUY= EMPTY; ALTBUY.Name="ALTBUY";
				FormulaData ALTSELL=EMPTY; ALTSELL.Name="ALTSELL";
				FormulaData BALANCE= 10000.0; BALANCE.Name="BALANCE";
				FormulaData BT= BACKTEST(C,BUY,SELL,0,0,BALANCE[0],0.000342,1,ALTBUY,ALTSELL); BT.Name="BT";
				FormulaData NONAME0=DRAWICON(SELL , BT ,"Sell.Gif");NONAME0.SetAttrs("Top");
				FormulaData NONAME1=DRAWICON(BUY , BT ,"Buy.Gif");NONAME1.SetAttrs("Bottom");
				FormulaData AMT= BALANCE/C[0]; AMT.Name="AMT";
				FormulaData MAXPERF= (BALANCE/LLV(L))*HHV(H); MAXPERF.Name="MaxPerf";
				FormulaData NONAME2=BT;
				FormulaData PERF=C*AMT; PERF.Name="Perf";
				FormulaData NONAME3=BALANCE;NONAME3.SetAttrs("ColorDarkRed");
				FormulaData NONAME4=MAXPERF;NONAME4.SetAttrs(" DarkGreen,Width2");
				return new FormulaPackage(new FormulaData[]{NONAME0,NONAME1,NONAME2,PERF,NONAME3,NONAME4},"");
			}
		
			public override string LongName
			{
				get{return "MACD Trading System";}
			}
		
			public override string Description
			{
				get{return "MACD Trading System";}
			}
			public override string OutputFields
			{
				get{return "DRAWICON(SELL , BT ,\"Sell.Gif\"),DRAWICON(BUY , BT ,\"Buy.Gif\"),BT,Perf,BALANCE,MaxPerf";}
			}
		} //class MACD

		[System.Serializable]
		public class _T_ZARF:FormulaBase
		{
			public double OPT1=0;
			public double OPT2=0;
			public double OPT3=0;
			public _T_ZARF():base()
			{
				AddParam("OPT1","3","3","4","1","",FormulaParamType.Double);
				AddParam("OPT2","11","11","12","1","",FormulaParamType.Double);
				AddParam("OPT3","3","3","4","1","",FormulaParamType.Double);
			}
		
			public override FormulaPackage Run(IFormulaDataProvider DP)
			{
				this.DataProvider = DP;
				FormulaData SIS=FML(DP,"MACD(26,12,9)"); SIS.Name="SIS";
				FormulaData YUKARI=CROSS(SIS,0); YUKARI.Name="Yukari";
				FormulaData ASAGI=CROSS(0,SIS); ASAGI.Name="Asagi";
				FormulaData YTREND=SIS>0; YTREND.Name="Ytrend";
				FormulaData ATREND=SIS<0; ATREND.Name="Atrend";
				FormulaData YREF=REF(L,-1); YREF.Name="YRef";
				FormulaData AREF=REF(H,-1); AREF.Name="ARef";
				FormulaData SOYN=REF(FML(DP,"ATR(14)"),-1); SOYN.Name="sOyn";
				FormulaData SYKAL=2-REF(FML(DP,"VHF(C,14)"),-1); SYKAL.Name="sYKal";
				FormulaData SAKAL= 2-REF(FML(DP,"VHF(C,14)"),-1); SAKAL.Name="sAkal";
				FormulaData SYSTP=YREF-SOYN*SYKAL; SYSTP.Name="sYstp";
				FormulaData SASTP=AREF+SOYN*SAKAL; SASTP.Name="sAstp";
				FormulaData STT=IF(YTREND,HIGHESTSINCE(1,YUKARI,SYSTP), LOWESTSINCE(1,ASAGI,SASTP)); STT.Name="sTT";
				FormulaData SYT=IF(YTREND & C>STT ,STT,PREV); SYT.Name="sYT";
				FormulaData SAT=IF(ATREND & C<STT ,STT,PREV); SAT.Name="sAT";
				FormulaData SARI=IF(YTREND,SYT,SAT); SARI.Name="SARI";
				FormulaData TR=RSQUARED(C,14); TR.Name="TR";
				FormulaData TRM=MOV(TR,9,S); TRM.Name="TRM";
				FormulaData YATAY=4/10; YATAY.Name="Yatay";
				FormulaData YTG= CROSS(YATAY,TR) | (TR>YATAY & CROSS(TRM,TR) ); YTG.Name="YTG";
				FormulaData YTC=TR>TRM & TR>YATAY; YTC.Name="YTC";
				FormulaData YTY=BARSSINCE(YTG)<BARSSINCE(YTC); YTY.Name="YTY";
				FormulaData FARK=(1+TR)*REF(MOV(MAX(O,C)-MIN(O,C),14,S),-1); FARK.Name="Fark";
				FormulaData HX=REF(MOV(MAX(O,C)+FARK,5,S),-1); HX.Name="HX";
				FormulaData LX=REF(MOV(MIN(O,C)-FARK,5,S),-1); LX.Name="LX";
				FormulaData HS=IF(TR>YATAY & TR>TRM, LOWESTSINCE(1,YTC,HX), VALUEWHEN(1,YTG,HX)); HS.Name="HS";
				FormulaData LS=IF(TR>YATAY & TR>TRM, HIGHESTSINCE(1,YTC,LX), VALUEWHEN(1,YTG,LX)); LS.Name="LS";
				FormulaData HXX=MAX(HS,SARI); HXX.Name="HXX";
				FormulaData LXX=MIN(LS,SARI); LXX.Name="LXX";
				FormulaData P1=OPT1; P1.Name="p1";
				FormulaData P2=OPT2; P2.Name="p2";
				FormulaData R1=1; R1.Name="r1";
				FormulaData P3=P2; P3.Name="p3";
				FormulaData YY=OPT3; YY.Name="yy";
				FormulaData AA=MOV(C,P1,W); AA.Name="AA";
				FormulaData BB=MOV(AA,P2,W); BB.Name="BB";
				FormulaData XAA=AA - REF(AA,-R1); XAA.Name="XAA";
				FormulaData XBB=BB - REF(BB,-R1); XBB.Name="XBB";
				FormulaData XAB= ABS(AA - BB); XAB.Name="XAB";
				FormulaData OAB= (XAA+XBB)/2; OAB.Name="OAB";
				FormulaData PP= XAB* OAB * OAB* OAB; PP.Name="PP";
				FormulaData XPP=100*PP/HHV(ABS(PP),P3); XPP.Name="XPP";
				FormulaData YUZDE=1000*(HXX-LXX)/LXX; YUZDE.Name="Yuzde";
				FormulaData BUY=C>HXX; BUY.Name="BUY";BUY.SetAttrs("ColorDarkGreen");
				FormulaData SELL=C<LXX; SELL.Name="SELL";SELL.SetAttrs(" ColorRed");
				FormulaData OPENSELL=C<LXX; OPENSELL.Name="OPENSELL";OPENSELL.SetAttrs("ColorDarkOrange");
				FormulaData CLOSEOPENSELL=C>HXX; CLOSEOPENSELL.Name="CLOSEOPENSELL";CLOSEOPENSELL.SetAttrs(" ColorDarkViolet");
				FormulaData ALTBUY= EMPTY; ALTBUY.Name="ALTBUY";
				FormulaData ALTSELL=EMPTY; ALTSELL.Name="ALTSELL";
				FormulaData BALANCE= 10000.0; BALANCE.Name="BALANCE";
				FormulaData BT= BACKTEST(C,BUY,SELL,OPENSELL,CLOSEOPENSELL,BALANCE[0],0.000342,1,ALTBUY,ALTSELL); BT.Name="BT";
				FormulaData NONAME0=DRAWICON(SELL , BT ,"Sell.Gif");NONAME0.SetAttrs("Top");
				FormulaData NONAME1=DRAWICON(BUY , BT ,"Buy.Gif");NONAME1.SetAttrs("Bottom");
				FormulaData NONAME2=DRAWICON(OPENSELL, BT ,"OpenSell.Gif");NONAME2.SetAttrs("Top");
				FormulaData NONAME3=DRAWICON(CLOSEOPENSELL, BT ,"CloseOpenSell.Gif");NONAME3.SetAttrs("Bottom");
				FormulaData MAXPERF= (BALANCE/LLV(L))*HHV(H); MAXPERF.Name="MaxPerf";
				FormulaData NONAME4=BT;
				FormulaData NONAME5=MAXPERF;NONAME5.SetAttrs(" DarkGreen,Width2");
				return new FormulaPackage(new FormulaData[]{NONAME0,NONAME1,NONAME2,NONAME3,NONAME4,NONAME5},"");
			}
		
			public override string LongName
			{
				get{return "Zarf Trading signals ";}
			}
		
			public override string Description
			{
				get{return "";}
			}
			public override string OutputFields
			{
				get{return "DRAWICON(SELL , BT ,\"Sell.Gif\"),DRAWICON(BUY , BT ,\"Buy.Gif\"),DRAWICON(OPENSELL, BT ,\"OpenSell.Gif\"),DRAWICON(CLOSEOPENSELL, BT ,\"CloseOpenSell.Gif\"),BT,MaxPerf";}
			}
		} //class _T_ZARF

		[System.Serializable]
		public class _T_RSI:FormulaBase
		{
			public double N=0;
			public double UP=0;
			public double DW=0;
			public double OUP=0;
			public double ODW=0;
			public _T_RSI():base()
			{
				AddParam("N","14","3","8","2","",FormulaParamType.Double);
				AddParam("UP","70","-95","95","15","",FormulaParamType.Double);
				AddParam("DW","30","-95","95","15","",FormulaParamType.Double);
				AddParam("OUP","70","-95","95","15","",FormulaParamType.Double);
				AddParam("ODW","30","-95","95","15","",FormulaParamType.Double);
			}
		
			public override FormulaPackage Run(IFormulaDataProvider DP)
			{
				this.DataProvider = DP;
				FormulaData BUY=CROSS(FML(DP,"RSI(N)"),DW); BUY.Name="BUY";BUY.SetAttrs("ColorDarkGreen");
				FormulaData SELL=CROSS(UP,FML(DP,"RSI(N)")); SELL.Name="SELL";SELL.SetAttrs("ColorRed");
				FormulaData CLOSEOPENPOSITION=CROSS(FML(DP,"RSI(N)"),ODW); CLOSEOPENPOSITION.Name="CLOSEOPENPOSITION";CLOSEOPENPOSITION.SetAttrs("ColorDarkGreen");
				FormulaData OPENSELL=CROSS(OUP,FML(DP,"RSI(N)")); OPENSELL.Name="OPENSELL";OPENSELL.SetAttrs("ColorRed");
				FormulaData ALTBUY= EMPTY; ALTBUY.Name="ALTBUY";
				FormulaData ALTSELL=EMPTY; ALTSELL.Name="ALTSELL";
				FormulaData BALANCE= 10000.0; BALANCE.Name="BALANCE";
				FormulaData BT= BACKTEST(C,BUY,SELL,OPENSELL,CLOSEOPENPOSITION,BALANCE[0],0.000342,1,ALTBUY,ALTSELL); BT.Name="BT";
				FormulaData NONAME0=DRAWICON(SELL , BT ,"Sell.Gif");NONAME0.SetAttrs("Top");
				FormulaData NONAME1=DRAWICON(BUY , BT ,"Buy.Gif");NONAME1.SetAttrs("Bottom");
				FormulaData NONAME2=DRAWICON(OPENSELL, BT ,"OpenSell.Gif");NONAME2.SetAttrs("Top");
				FormulaData NONAME3=DRAWICON(CLOSEOPENPOSITION, BT ,"CloseOpenSell.Gif");NONAME3.SetAttrs("Bottom");
				FormulaData MAXPERF= (BALANCE/LLV(L))*HHV(H); MAXPERF.Name="MaxPerf";
				FormulaData NONAME4=BT;
				FormulaData NONAME5=MAXPERF;NONAME5.SetAttrs(" DarkGreen,Width2");
				return new FormulaPackage(new FormulaData[]{NONAME0,NONAME1,NONAME2,NONAME3,NONAME4,NONAME5},"");
			}
		
			public override string LongName
			{
				get{return "";}
			}
		
			public override string Description
			{
				get{return "";}
			}
			public override string OutputFields
			{
				get{return "DRAWICON(SELL , BT ,\"Sell.Gif\"),DRAWICON(BUY , BT ,\"Buy.Gif\"),DRAWICON(OPENSELL, BT ,\"OpenSell.Gif\"),DRAWICON(CLOSEOPENPOSITION, BT ,\"CloseOpenSell.Gif\"),BT,MaxPerf";}
			}
		} //class _T_RSI

		[System.Serializable]
		public class A_RSI:FormulaBase
		{
			public double N=0;
			public double UP=0;
			public double DW=0;
			public double OUP=0;
			public double ODW=0;
			public A_RSI():base()
			{
				AddParam("N","14","0","100","0","",FormulaParamType.Double);
				AddParam("UP","70","-95","95","10","",FormulaParamType.Double);
				AddParam("DW","30","-95","95","10","",FormulaParamType.Double);
				AddParam("OUP","70","-95","95","10","",FormulaParamType.Double);
				AddParam("ODW","30","-95","95","10"," ",FormulaParamType.Double);
			}
		
			public override FormulaPackage Run(IFormulaDataProvider DP)
			{
				this.DataProvider = DP;
				FormulaData BUY=CROSS(FML(DP,"RSI(N)"),DW); BUY.Name="BUY";BUY.SetAttrs("ColorDarkGreen");
				FormulaData SELL=CROSS(UP,FML(DP,"RSI(N)")); SELL.Name="SELL";SELL.SetAttrs("ColorRed");
				FormulaData CLOSEOPENPOSITION=CROSS(FML(DP,"RSI(N)"),ODW); CLOSEOPENPOSITION.Name="CLOSEOPENPOSITION";CLOSEOPENPOSITION.SetAttrs("ColorDarkGreen");
				FormulaData OPENSELL=CROSS(OUP,FML(DP,"RSI(N)")); OPENSELL.Name="OPENSELL";OPENSELL.SetAttrs("ColorRed");
				FormulaData BALANCE= 10000.0; BALANCE.Name="BALANCE";
				FormulaData NONAME0=DRAWICON(OPENSELL, C+0.01 ,"OpenSell.Gif");NONAME0.SetAttrs("Top");
				FormulaData NONAME1=DRAWICON(SELL , C ,"Sell.Gif");NONAME1.SetAttrs("Top");
				FormulaData NONAME2=DRAWICON(BUY , C ,"Buy.Gif");NONAME2.SetAttrs("Bottom");
				FormulaData NONAME3=DRAWICON(CLOSEOPENPOSITION, C-0.01 ,"CloseOpenSell.Gif");NONAME3.SetAttrs("Bottom");
				
				return new FormulaPackage(new FormulaData[]{NONAME0,NONAME1,NONAME2,NONAME3},"");
			}
		
			public override string LongName
			{
				get{return "";}
			}
		
			public override string Description
			{
				get{return "";}
			}
			public override string OutputFields
			{
				get{return "DRAWICON(OPENSELL, C+0.01 ,\"OpenSell.Gif\"),DRAWICON(SELL , C ,\"Sell.Gif\"),DRAWICON(BUY , C ,\"Buy.Gif\"),DRAWICON(CLOSEOPENPOSITION, C-0.01 ,\"CloseOpenSell.Gif\")";}
			}
		} //class A_RSI

