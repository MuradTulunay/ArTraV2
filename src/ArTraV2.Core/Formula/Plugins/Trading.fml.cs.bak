		[System.Serializable]
		public class _T_ZIGAD:FormulaBase
		{
			public double SPR=0;
			public double SL=0;
			public _T_ZIGAD():base()
			{
				AddParam("SPR","0.35","0.01","5","0.01","HHV ve LLV periodu",FormulaParamType.Double);
				AddParam("SL","0","0","100","0","",FormulaParamType.Double);
			}
		
			public override FormulaPackage Run(IFormulaDataProvider DP)
			{
				this.DataProvider = DP;
				FormulaData AD=SUM(((CLOSE-LOW)-(HIGH-CLOSE))/(HIGH-LOW)*VOL,0); AD.Name="AD";
				FormulaData SIG=EMPTY; SIG.Name="SIG";
				FormulaData Z= ZIGP(AD,SPR,SIG); Z.Name="Z";
				FormulaData BUY=SIG>1; BUY.Name="BUY";
				FormulaData SELL=SIG<-1; SELL.Name="SELL";SELL.SetAttrs("ColorRed");
				FormulaData ALTBUY= EMPTY; ALTBUY.Name="ALTBUY";
				FormulaData ALTSELL=EMPTY; ALTSELL.Name="ALTSELL";
				FormulaData STOPLOSS=EMPTY; STOPLOSS.Name="STOPLOSS";
				FormulaData BALANCE= 10000.0; BALANCE.Name="BALANCE";
				FormulaData BT= BACKTEST(C,BUY,SELL,0,0,BALANCE[0],0.000342,1,ALTBUY,ALTSELL,SL,STOPLOSS,0.00,TRUE); BT.Name="BT";
				FormulaData NONAME0=DRAWICON(SELL , BT ,"Sell.Gif");NONAME0.SetAttrs("Top");
				FormulaData NONAME1=DRAWICON(BUY , BT ,"Buy.Gif");NONAME1.SetAttrs("Bottom");
				FormulaData STOPBUYS= STOPLOSS>0; STOPBUYS.Name="STOPBUYS";
				FormulaData STOPSELLS=STOPLOSS<0; STOPSELLS.Name="STOPSELLS";
				FormulaData NONAME2=DRAWICON(STOPSELLS , BT ,"StopSell.Gif");NONAME2.SetAttrs("Top");
				FormulaData NONAME3=DRAWICON(STOPBUYS , BT ,"StopBuy.Gif");NONAME3.SetAttrs("Bottom");
				FormulaData MAXPERF= (BALANCE/LLV(L))*HHV(H); MAXPERF.Name="MaxPerf";
				FormulaData NONAME4=BT;
				FormulaData NONAME5=MAXPERF;NONAME5.SetAttrs(" DarkGreen,Width2");
				return new FormulaPackage(new FormulaData[]{NONAME0,NONAME1,NONAME2,NONAME3,NONAME4,NONAME5},"");
			}
		
			public override string LongName
			{
				get{return "";}
			}
		
			public override string Description
			{
				get{return "MB ortalama yukarı kesilince alınır. MS aşağı kesilince satılır.\n\n";}
			}
			public override string OutputFields
			{
				get{return "DRAWICON(SELL , BT ,\"Sell.Gif\"),DRAWICON(BUY , BT ,\"Buy.Gif\"),DRAWICON(STOPSELLS , BT ,\"StopSell.Gif\"),DRAWICON(STOPBUYS , BT ,\"StopBuy.Gif\"),BT,MaxPerf";}
			}
		} //class _T_ZIGAD

