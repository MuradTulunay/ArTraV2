			{
				get{return "RSI Trading system\n\n\n\n\n";}
			}
			public override string OutputFields
			{
				get{return "DRAWICON(OPENSELL , C ,\"OpenSell.Gif\"),DRAWICON(CLOSEOPENPOSITION, C ,\"CloseOpenSell.Gif\")";}
			}
		} //class A_SAR_SA

		[System.Serializable]
		public class _T_RSI_E:FormulaBase
		{
			public double N=0;
			public double UP=0;
			public double DW=0;
			public double OUP=0;
			public double ODW=0;
			public double N1=0;
			public double UP1=0;
			public double DW1=0;
			public _T_RSI_E():base()
			{
				AddParam("N","7","6","8","1","",FormulaParamType.Double);
				AddParam("UP","70","62","76","2","",FormulaParamType.Double);
				AddParam("DW","25","19","29","2","",FormulaParamType.Double);
				AddParam("OUP","-5","-10","0","3","",FormulaParamType.Double);
				AddParam("ODW","-67","-69","-59","2","",FormulaParamType.Double);
				AddParam("N1","3","2","4","1","",FormulaParamType.Double);
				AddParam("UP1","-80","-84","-76","2","",FormulaParamType.Double);
				AddParam("DW1","5","1","9","2","",FormulaParamType.Double);
			}
		
			public override FormulaPackage Run(IFormulaDataProvider DP)
			{
				this.DataProvider = DP;
				FormulaData BUY=CROSS(FML(DP,"RSI(N)"),DW) | CROSS(FML(DP,"RSI(N1)"),DW1) ; BUY.Name="BUY";BUY.SetAttrs("ColorDarkGreen");
				FormulaData SELL=CROSS(UP,FML(DP,"RSI(N)")) | CROSS(UP1,FML(DP,"RSI(N1)")); SELL.Name="SELL";SELL.SetAttrs("ColorRed");
				FormulaData CLOSEOPENPOSITION=CROSS(FML(DP,"RSI(N)"),ODW); CLOSEOPENPOSITION.Name="CLOSEOPENPOSITION";CLOSEOPENPOSITION.SetAttrs("ColorDarkGreen");
				FormulaData OPENSELL=CROSS(OUP,FML(DP,"RSI(N)")); OPENSELL.Name="OPENSELL";OPENSELL.SetAttrs("ColorRed");
				FormulaData ALTBUY= EMPTY; ALTBUY.Name="ALTBUY";
				FormulaData ALTSELL=EMPTY; ALTSELL.Name="ALTSELL";
				FormulaData BALANCE= 10000.0; BALANCE.Name="BALANCE";
				FormulaData BT= BACKTEST(C,BUY,SELL,OPENSELL,CLOSEOPENPOSITION,BALANCE[0],0.000342,1,ALTBUY,ALTSELL); BT.Name="BT";
				FormulaData NONAME0=DRAWICON(SELL , BT ,"Sell.Gif");NONAME0.SetAttrs("Top");
				FormulaData NONAME1=DRAWICON(BUY , BT ,"Buy.Gif");NONAME1.SetAttrs("Bottom");
				FormulaData NONAME2=DRAWICON(OPENSELL, BT ,"OpenSell.Gif");NONAME2.SetAttrs("Top");
				FormulaData NONAME3=DRAWICON(CLOSEOPENPOSITION, BT ,"CloseOpenSell.Gif");NONAME3.SetAttrs("Bottom");
				FormulaData AMT= BALANCE/C[0]; AMT.Name="AMT";
				FormulaData MAXPERF= (BALANCE/LLV(L))*HHV(H); MAXPERF.Name="MaxPerf";
				FormulaData NONAME4=BT;
				FormulaData NONAME5=MAXPERF;NONAME5.SetAttrs(" DarkGreen,Width2");
				return new FormulaPackage(new FormulaData[]{NONAME0,NONAME1,NONAME2,NONAME3,NONAME4,NONAME5},"");
			}
		
			public override string LongName
			{
				get{return "";}
			}
		
			public override string Description
			{
				get{return "";}
			}
			public override string OutputFields
			{
				get{return "DRAWICON(SELL , BT ,\"Sell.Gif\"),DRAWICON(BUY , BT ,\"Buy.Gif\"),DRAWICON(OPENSELL, BT ,\"OpenSell.Gif\"),DRAWICON(CLOSEOPENPOSITION, BT ,\"CloseOpenSell.Gif\"),BT,MaxPerf";}
			}
		} //class _T_RSI_E

