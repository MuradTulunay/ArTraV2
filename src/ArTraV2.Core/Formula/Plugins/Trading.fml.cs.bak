				get{return "DRAWICON(SELL , C ,\"Sell.Gif\"),DRAWICON(BUY , C ,\"Buy.Gif\"),DRAWICON(OPENSELL, C ,\"OpenSell.Gif\"),DRAWICON(CLOSEOPENPOSITION, C ,\"CloseOpenSell.Gif\"),DRAWICON(STOPSELLS , C,\"StopSell.Gif\"),DRAWICON(STOPBUYS ,C ,\"StopBuy.Gif\")";}
			}
		} //class A_RSISL

